#!/bin/bash
# Launched by launchd via com.user.homebrew-ssh-agent.plist.
# Cleans up any stale socket before starting the agent so that
# "Address already in use" restart loops don't occur after unclean shutdowns.

SOCKET="/Users/grim_reaper/.ssh/agent.sock"

# Remove stale socket if it exists but has no owning process
if [ -S "$SOCKET" ]; then
    rm -f "$SOCKET"
fi

exec /opt/homebrew/bin/ssh-agent -D -a "$SOCKET"
